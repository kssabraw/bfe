---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Thank You – Be Found Everywhere" description="We received your message.">
  <section class="section section--light thanks-section">
    <div class="container">
      <div class="card thanks-card">
        <h1>Thank you!</h1>
        <p>We received your message and will get back to you shortly.</p>
        <a class="btn btn--primary" href={`${base}/`}>Back to home</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .thanks-section {
    min-height: 55vh;
    display: flex;
    align-items: center;
  }
  .thanks-card {
    max-width: 520px;
    margin: 0 auto;
    text-align: center;
    padding: 56px 40px;
  }
  .thanks-card p {
    margin-bottom: 28px;
  }
</style>
