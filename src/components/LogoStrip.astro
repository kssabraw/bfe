---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div class="logo-strip-wrap">
  <p class="logo-strip-label">As seen on</p>
  <div class="logo-strip">
    <img
      src={`${base}/images/as-seen-on.png`}
      alt="As seen on ABC, CBS, FOX, and NBC"
      loading="lazy"
    />
  </div>
</div>

<style>
  .logo-strip-wrap {
    text-align: center;
    margin-top: 56px;
  }
  .logo-strip-label {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-muted);
    margin-bottom: 20px;
  }
  .logo-strip {
    display: flex;
    justify-content: center;
  }
  .logo-strip img {
    height: 38px;
    width: auto;
    max-width: 100%;
    opacity: 0.85;
  }
</style>
