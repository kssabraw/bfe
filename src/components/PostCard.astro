---
interface Props {
  slug: string;
  title: string;
  description: string;
  pubDate: Date;
  heroImage?: string;
}
const { slug, title, description, pubDate, heroImage } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const heroSrc = heroImage
  ? (/^https?:\/\//.test(heroImage) ? heroImage : `${base}${heroImage}`)
  : undefined;
const dateFmt = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="post-card card">
  <a href={`${base}/blog/${slug}/`} class="post-card-link">
    {heroSrc && <img src={heroSrc} alt="" loading="lazy" class="post-card-img" />}
    <div class="post-card-body">
      <time datetime={pubDate.toISOString()}>{dateFmt}</time>
      <h3>{title}</h3>
      <p>{description}</p>
    </div>
  </a>
</article>

<style>
  .post-card {
    padding: 0;
    overflow: hidden;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .post-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 36px rgba(60, 34, 102, 0.14);
  }
  .post-card-link { display: block; color: inherit; }
  .post-card-link:hover { text-decoration: none; }
  .post-card-img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }
  .post-card-body { padding: 22px 24px 26px; }
  .post-card-body time {
    font-size: 13px;
    color: var(--c-muted);
  }
  .post-card-body h3 {
    margin: 8px 0 10px;
    font-size: 1.1rem;
  }
  .post-card-body p {
    font-size: 14px;
    color: var(--c-text);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
