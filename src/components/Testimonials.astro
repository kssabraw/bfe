---
import { testimonials } from '../lib/data';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="section section--light">
  <div class="container">
    <div class="section-intro">
      <span class="eyebrow">Customer Stories</span>
      <h2>Success Stories from Leading Brands</h2>
    </div>
    <div class="testimonial-grid">
      {testimonials.map((t) => (
        <figure class="card testimonial">
          <blockquote>“{t.quote}”</blockquote>
          <figcaption>
            <img src={`${base}${t.photo}`} alt={t.name} loading="lazy" />
            <div>
              <strong>{t.name}</strong>
              <span>{t.role}</span>
            </div>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonial-grid {
    columns: 3;
    column-gap: 28px;
  }
  .testimonial {
    break-inside: avoid;
    margin-bottom: 28px;
    padding: 28px;
  }
  .testimonial blockquote {
    margin: 0 0 20px;
    font-size: 15px;
    color: var(--c-text);
  }
  .testimonial figcaption {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .testimonial img {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
  }
  .testimonial strong {
    display: block;
    color: var(--c-navy);
    font-size: 14px;
  }
  .testimonial span {
    font-size: 13px;
    color: var(--c-muted);
  }
  @media (max-width: 1000px) {
    .testimonial-grid { columns: 2; }
  }
  @media (max-width: 640px) {
    .testimonial-grid { columns: 1; }
  }
</style>
