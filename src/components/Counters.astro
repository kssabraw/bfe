---
import { counters } from '../lib/data';
---

<div class="counters">
  {counters.map((c) => (
    <div class="counter">
      <span class="counter-value">{c.prefix ?? ''}{c.value}</span>
      <span class="counter-label">{c.label}</span>
    </div>
  ))}
</div>

<style>
  .counters {
    display: flex;
    justify-content: center;
    gap: 64px;
    flex-wrap: wrap;
    margin-top: 48px;
  }
  .counter {
    text-align: center;
  }
  .counter-value {
    display: block;
    font-size: 2.75rem;
    font-weight: 800;
    color: var(--c-primary);
    line-height: 1;
  }
  .counter-label {
    display: block;
    margin-top: 8px;
    font-size: 14px;
    color: var(--c-muted);
    font-weight: 600;
  }
</style>
