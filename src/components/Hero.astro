---
import LogoStrip from './LogoStrip.astro';

interface Props {
  eyebrow: string;
  title: string;
  text: string;
  ctaLabel: string;
  ctaHref: string;
  videoId?: string;
  image?: string;
  logos?: boolean;
  banner?: string;
}
const { eyebrow, title, text, ctaLabel, ctaHref, videoId, image, logos = true, banner } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="section hero">
  <div class="container">
    {banner && (
      <p class="hero-banner"><span class="hero-banner-tag">New</span> {banner}</p>
    )}
    <div class="hero-inner">
      <span class="eyebrow">{eyebrow}</span>
      <h1>{title}</h1>
      <p class="hero-text">{text}</p>
      <a class="btn btn--primary hero-cta" href={ctaHref} rel="noopener">{ctaLabel}</a>
    </div>
    {videoId && (
      <div class="hero-media">
        <iframe
          src={`https://www.youtube-nocookie.com/embed/${videoId}`}
          title="Product demo video"
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        />
      </div>
    )}
    {!videoId && image && (
      <div class="hero-media">
        <img src={`${base}${image}`} alt="Product screenshot" loading="eager" />
      </div>
    )}
    {logos && <LogoStrip />}
  </div>
</section>

<style>
  .hero {
    background:
      radial-gradient(60% 80% at 50% 0%, rgba(149, 84, 255, 0.1) 0%, transparent 70%),
      var(--c-bg-light);
    padding-top: 56px;
  }
  .hero-banner {
    text-align: center;
    margin-bottom: 28px;
    font-weight: 600;
    color: var(--c-navy);
    font-size: 14px;
  }
  .hero-banner-tag {
    background: var(--c-primary);
    color: var(--c-white);
    font-size: 12px;
    font-weight: 700;
    border-radius: 999px;
    padding: 3px 10px;
    margin-right: 8px;
  }
  .hero-inner {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }
  .hero-text {
    font-size: 17px;
    margin: 18px 0 28px;
  }
  .hero-cta {
    font-size: 16px;
    padding: 15px 34px;
  }
  .hero-media {
    max-width: 860px;
    margin: 52px auto 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(60, 34, 102, 0.2);
  }
  .hero-media iframe {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 0;
  }
</style>
