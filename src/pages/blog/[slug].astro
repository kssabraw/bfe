---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import SidebarCTA from '../../components/SidebarCTA.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;
const { Content } = await render(post);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
// heroImage may be a repo-local path (/images/...) or an absolute URL from the
// publishing platform — only local paths get the base prefix.
const heroSrc = post.data.heroImage
  ? (/^https?:\/\//.test(post.data.heroImage) ? post.data.heroImage : `${base}${post.data.heroImage}`)
  : undefined;
const dateFmt = post.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base
  title={`${post.data.title} – Be Found Everywhere`}
  description={post.data.description}
  ogImage={post.data.heroImage}
  ogType="article"
>
  <div class="section">
    <div class="container">
      <header class="post-header">
        <a href={`${base}/blog/`} class="back-link">← All posts</a>
        <h1>{post.data.title}</h1>
        <p class="post-meta">
          <time datetime={post.data.pubDate.toISOString()}>{dateFmt}</time>
          · {post.data.author}
        </p>
      </header>
      {heroSrc && <img src={heroSrc} alt="" class="post-hero" />}
      <div class="post-grid">
        <article class="post-body">
          <Content />
        </article>
        <aside class="post-aside">
          <SidebarCTA />
        </aside>
      </div>
    </div>
  </div>
</Base>

<style>
  .post-header { max-width: 760px; }
  .back-link {
    font-size: 14px;
    font-weight: 600;
    display: inline-block;
    margin-bottom: 20px;
  }
  .post-meta {
    color: var(--c-muted);
    font-size: 14px;
    margin-bottom: 28px;
  }
  .post-hero {
    width: 100%;
    border-radius: var(--radius-lg);
    margin-bottom: 44px;
  }
  .post-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 340px;
    gap: 56px;
    align-items: start;
  }
  .post-body { max-width: 720px; }
  .post-aside {
    position: sticky;
    top: 92px;
    min-width: 0;
  }
  @media (max-width: 900px) {
    .post-grid { grid-template-columns: 1fr; }
    .post-aside {
      position: static;
      max-width: 480px;
    }
  }
  .post-body :global(h2) {
    margin-top: 1.8em;
    font-size: 1.5rem;
  }
  .post-body :global(h3) {
    margin-top: 1.4em;
  }
  .post-body :global(img) {
    border-radius: var(--radius);
    margin: 1.5em 0;
  }
  .post-body :global(li) {
    margin-bottom: 0.4em;
  }
  .post-body :global(blockquote) {
    border-left: 3px solid var(--c-primary);
    background: var(--c-bg-light);
    border-radius: 0 var(--radius) var(--radius) 0;
    margin: 1.8em 0;
    padding: 1em 1.4em;
    color: var(--c-navy);
    font-size: 1.08rem;
    font-weight: 500;
  }
  .post-body :global(blockquote p) {
    margin: 0;
  }
  .post-body :global(.key-takeaways) {
    background: var(--c-bg-light);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    padding: 1.6em 1.8em;
    margin: 2em 0;
  }
  .post-body :global(.key-takeaways h2),
  .post-body :global(.key-takeaways h3) {
    margin: 0 0 0.7em;
    font-size: 1.2rem;
    color: var(--c-deep-purple);
  }
  .post-body :global(.key-takeaways h2)::before,
  .post-body :global(.key-takeaways h3)::before {
    content: '✦ ';
    color: var(--c-primary);
  }
  .post-body :global(.key-takeaways ul),
  .post-body :global(.key-takeaways ol) {
    margin: 0;
    padding-left: 1.3em;
  }
  .post-body :global(.key-takeaways li) {
    margin-bottom: 0.5em;
  }
  .post-body :global(.key-takeaways li:last-child) {
    margin-bottom: 0;
  }
  .post-body :global(.table-wrap) {
    overflow-x: auto;
    margin: 1.8em 0;
    border: 1px solid var(--c-border);
    border-radius: var(--radius);
  }
  .post-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }
  .post-body :global(th) {
    background: var(--c-bg-light);
    color: var(--c-navy);
    text-align: left;
    font-weight: 600;
    padding: 0.7em 1em;
    border-bottom: 2px solid var(--c-border);
    white-space: nowrap;
  }
  .post-body :global(td) {
    padding: 0.7em 1em;
    border-bottom: 1px solid var(--c-border);
    vertical-align: top;
  }
  .post-body :global(tr:last-child td) {
    border-bottom: none;
  }
</style>
