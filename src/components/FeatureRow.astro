---
interface Props {
  title: string;
  desc: string;
  image?: string;
  flip?: boolean;
}
const { title, desc, image, flip = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div class={`feature-row ${flip ? 'feature-row--flip' : ''}`}>
  <div class="feature-copy">
    <h3>{title}</h3>
    <p>{desc}</p>
  </div>
  {image && (
    <div class="feature-img">
      <img src={`${base}${image}`} alt="" loading="lazy" />
    </div>
  )}
</div>

<style>
  .feature-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    margin-bottom: 64px;
  }
  .feature-row:last-child { margin-bottom: 0; }
  .feature-row--flip .feature-copy { order: 2; }
  .feature-row--flip .feature-img { order: 1; }
  .feature-copy h3 {
    font-size: 1.4rem;
    margin-bottom: 12px;
  }
  .feature-copy p {
    margin: 0;
    font-size: 15px;
  }
  .feature-img img {
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    border: 1px solid var(--c-border);
  }
  @media (max-width: 820px) {
    .feature-row {
      grid-template-columns: 1fr;
      gap: 20px;
      margin-bottom: 48px;
    }
    .feature-row--flip .feature-copy { order: 1; }
    .feature-row--flip .feature-img { order: 2; }
  }
</style>
